---
import { latestPrograms, donasiUrl } from '../data/programs';
---

<section class="section-pad" id="program">
  <div class="container">
    <div class="programs-head">
      <div data-reveal>
        <div class="eyebrow"><span class="section-num">03 / Program Donasi</span></div>
        <h2 class="display">
          Pilih amal terbaik<br/>yang ingin Anda <em>titipkan</em>.
        </h2>
      </div>
      <p class="lede" data-reveal>
        Setiap program di bawah ini bukan sekadar pilihan amal, tapi jawaban bagi mereka yang sedang menunggu bantuan hari ini.
      </p>
    </div>
    <div class="programs-grid">
      {latestPrograms.map((p) => (
        <article class="program-card" data-reveal>
          <div class="program-img skeleton">
            <img src={p.image} alt={p.alt} loading="lazy" decoding="async" width="800" height="600" />
            <span class="program-tag">{p.tag}</span>
          </div>
          <div class="program-body">
            <h3>{p.title}</h3>
            <p>{p.description}</p>
            <a href={donasiUrl(p.slug)} class="program-cta" target="_blank" rel="noopener noreferrer">
              Titipkan amanah <span class="arrow"><svg viewBox="0 0 24 24"><path d="M5 12h14M13 6l6 6-6 6"/></svg></span>
            </a>
          </div>
        </article>
      ))}
    </div>
    <div class="programs-foot" data-reveal>
      <a href="/program" class="btn btn-ghost">
        Lihat Semua Program
        <span class="arrow"><svg viewBox="0 0 24 24"><path d="M5 12h14M13 6l6 6-6 6"/></svg></span>
      </a>
    </div>
  </div>
</section>
